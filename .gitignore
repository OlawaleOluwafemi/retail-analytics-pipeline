# ==========================================
# 1. Environment Variables & Security (CRITICAL)
# ==========================================
.env
*.env
.secrets/
credentials/
*.pem
*.key

# ==========================================
# 2. Dagster & Python Internal Build Artifacts
# ==========================================
.dagster/
dagster_home/
storage/
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
env/
venv/
.venv/
pip-log.txt
pip-delete-this-directory.txt
.pytest_cache/
echo ".tmp_dagster_home_*" >> .gitignore

# ==========================================
# 3. dbt (Data Build Tool) Artifacts
# ==========================================
# Exclude the target/ and dbt_packages/ directories.
# We want to exclude target/ because manifest.json is dynamically updated and changes constantly.
transform_dbt/target/
transform_dbt/dbt_packages/
transform_dbt/logs/

# If your dbt folder has a different name, adjust the prefix below:
**/target/
**/dbt_packages/
**/dbt_modules/
**/logs/

# ==========================================
# 4. Docker Infrastructure & Database Volumes
# ==========================================
# Exclude local database storage engines to prevent committing gigabytes of raw data
.clickhouse_data/
clickhouse_data/
postgres_data/
superset_data/
grafana_data/

# Any localized docker volume directories you created on the host
**/data/clickhouse/
**/data/postgres/

# ==========================================
# 5. OS & IDE Specific Files
# ==========================================
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp